# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=3000
NODE_ENV=development

# Allowed origin for CORS / Socket.IO (the React client during dev)
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
# Get this from https://cloud.mongodb.com -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/quickchatter?retryWrites=true&w=majority

# JWT auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
